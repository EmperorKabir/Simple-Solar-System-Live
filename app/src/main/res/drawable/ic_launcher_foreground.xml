<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — Sun + 3 orbits + red, blue and ringed planets,
  plus tiny grey moons. ALL visual content is constrained to a centred 60dp
  circle (radius 30 from center 54,54), well inside the 66dp guaranteed-
  visible safe zone, so circle / square / squircle / teardrop / rounded-
  square mask shapes never clip the art.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ═════════════════════════════════════════════════════════════════
         ORBITS (drawn first so planets render above them)
         ═════════════════════════════════════════════════════════════════ -->

    <!-- Orbit 1 (innermost) — ellipse 14×5 -->
    <path android:strokeColor="#55FFFFFF"
          android:strokeWidth="0.4"
          android:fillColor="#00000000"
          android:pathData="M 54,54 m -14,0 a 14,5 0 1,0 28,0 a 14,5 0 1,0 -28,0"/>

    <!-- Orbit 2 — ellipse 22×8 -->
    <path android:strokeColor="#55FFFFFF"
          android:strokeWidth="0.4"
          android:fillColor="#00000000"
          android:pathData="M 54,54 m -22,0 a 22,8 0 1,0 44,0 a 22,8 0 1,0 -44,0"/>

    <!-- Orbit 3 (outermost) — ellipse 30×11 -->
    <path android:strokeColor="#55FFFFFF"
          android:strokeWidth="0.4"
          android:fillColor="#00000000"
          android:pathData="M 54,54 m -30,0 a 30,11 0 1,0 60,0 a 30,11 0 1,0 -60,0"/>

    <!-- ═════════════════════════════════════════════════════════════════
         SUN (centre) — radial gradient from white-hot core to orange edge
         ═════════════════════════════════════════════════════════════════ -->

    <!-- Subtle outer corona / glow -->
    <path android:pathData="M 54,54 m -12,0 a 12,12 0 1,0 24,0 a 12,12 0 1,0 -24,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="12"
                android:startColor="#80FFB347"
                android:endColor="#00FFB347"/>
        </aapt:attr>
    </path>

    <!-- Sun body -->
    <path android:pathData="M 54,54 m -8,0 a 8,8 0 1,0 16,0 a 8,8 0 1,0 -16,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="8"
                android:startColor="#FFF59D"
                android:endColor="#FF8F00"/>
        </aapt:attr>
    </path>

    <!-- ═════════════════════════════════════════════════════════════════
         RED PLANET on Orbit 1 (left side: 180°)
         Position: (54 - 14, 54) = (40, 54)
         ═════════════════════════════════════════════════════════════════ -->

    <path android:pathData="M 40,54 m -2.6,0 a 2.6,2.6 0 1,0 5.2,0 a 2.6,2.6 0 1,0 -5.2,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="39.2"
                android:centerY="53.4"
                android:gradientRadius="2.8"
                android:startColor="#FF7043"
                android:endColor="#B71C1C"/>
        </aapt:attr>
    </path>
    <!-- subtle highlight -->
    <path android:fillColor="#33FFFFFF"
          android:pathData="M 39.2,53.0 m -0.8,0 a 0.8,0.8 0 1,0 1.6,0 a 0.8,0.8 0 1,0 -1.6,0"/>

    <!-- ═════════════════════════════════════════════════════════════════
         EARTH-LIKE PLANET on Orbit 2 (upper-right: 30° above horizontal)
         Position: (54 + 22·cos30°, 54 - 8·sin30°) ≈ (73, 50)
         ═════════════════════════════════════════════════════════════════ -->

    <!-- Earth body — blue ocean -->
    <path android:pathData="M 73,50 m -3.4,0 a 3.4,3.4 0 1,0 6.8,0 a 3.4,3.4 0 1,0 -6.8,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="72.0"
                android:centerY="49.0"
                android:gradientRadius="3.6"
                android:startColor="#42A5F5"
                android:endColor="#0D47A1"/>
        </aapt:attr>
    </path>
    <!-- Green continent suggestion -->
    <path android:fillColor="#43A047"
          android:pathData="M 73.8,49.5 q -1.4,-1.0 -2.4,0.4 q 0.6,1.4 2.4,-0.4 z"/>
    <!-- Smaller continent dot -->
    <path android:fillColor="#388E3C"
          android:pathData="M 74.5,52 m -0.7,0 a 0.7,0.7 0 1,0 1.4,0 a 0.7,0.7 0 1,0 -1.4,0"/>

    <!-- Earth's grey moon (slightly outside Earth, upper-right) -->
    <path android:pathData="M 78.5,46.5 m -0.9,0 a 0.9,0.9 0 1,0 1.8,0 a 0.9,0.9 0 1,0 -1.8,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="78.2"
                android:centerY="46.2"
                android:gradientRadius="1.0"
                android:startColor="#E0E0E0"
                android:endColor="#757575"/>
        </aapt:attr>
    </path>

    <!-- ═════════════════════════════════════════════════════════════════
         SATURN-LIKE PLANET on Orbit 3 (lower-left: 210°)
         Position: (54 + 30·cos210°, 54 - 11·sin210°) ≈ (28, 60)
         ═════════════════════════════════════════════════════════════════ -->

    <!-- Saturn body -->
    <path android:pathData="M 28,60 m -4.4,0 a 4.4,4.4 0 1,0 8.8,0 a 4.4,4.4 0 1,0 -8.8,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="26.8"
                android:centerY="58.8"
                android:gradientRadius="4.6"
                android:startColor="#FFE082"
                android:endColor="#C68E17"/>
        </aapt:attr>
    </path>
    <!-- Saturn cloud bands (faint) -->
    <path android:strokeColor="#80A06410"
          android:strokeWidth="0.7"
          android:fillColor="#00000000"
          android:pathData="M 24.0,59.4 q 4.0,-0.8 8.0,0"/>
    <path android:strokeColor="#80A06410"
          android:strokeWidth="0.6"
          android:fillColor="#00000000"
          android:pathData="M 24.2,61.0 q 3.8,1.0 7.6,0"/>

    <!-- Saturn ring (drawn behind the body via lower z then a body-overlap arc) -->
    <path android:strokeColor="#D4AF37"
          android:strokeWidth="1.4"
          android:strokeLineCap="round"
          android:fillColor="#00000000"
          android:pathData="M 28,60 m -8.5,0 a 8.5,2.4 0 1,0 17,0 a 8.5,2.4 0 1,0 -17,0"/>
    <!-- Body redrawn over near-side ring segment for occlusion illusion -->
    <path android:pathData="M 28,60 m -4.4,0 a 4.4,4.4 -10 1,0 8.8,0 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="26.8"
                android:centerY="58.8"
                android:gradientRadius="4.6"
                android:startColor="#FFE082"
                android:endColor="#C68E17"/>
        </aapt:attr>
    </path>

    <!-- Saturn's grey moon (lower-left of Saturn) -->
    <path android:pathData="M 19,65 m -1.0,0 a 1.0,1.0 0 1,0 2.0,0 a 1.0,1.0 0 1,0 -2.0,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="18.7"
                android:centerY="64.7"
                android:gradientRadius="1.1"
                android:startColor="#E0E0E0"
                android:endColor="#757575"/>
        </aapt:attr>
    </path>
</vector>
