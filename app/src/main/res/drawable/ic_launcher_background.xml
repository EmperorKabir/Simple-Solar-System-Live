<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon background — full 108×108dp canvas, deep-space gradient.
  Extends to the full canvas so any mask shape (circle, square, squircle,
  teardrop) renders without transparent edges or cut-off seams.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Solid dark navy fills the full bleed area -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76"
                android:startColor="#1B2A4A"
                android:endColor="#050810"/>
        </aapt:attr>
    </path>

    <!-- A few faint stars sprinkled outside the safe zone (decorative) -->
    <path android:fillColor="#A0FFFFFF"
          android:pathData="M 14,18 m -0.7,0 a 0.7,0.7 0 1,0 1.4,0 a 0.7,0.7 0 1,0 -1.4,0"/>
    <path android:fillColor="#80FFFFFF"
          android:pathData="M 92,16 m -0.5,0 a 0.5,0.5 0 1,0 1.0,0 a 0.5,0.5 0 1,0 -1.0,0"/>
    <path android:fillColor="#A0FFFFFF"
          android:pathData="M 98,92 m -0.6,0 a 0.6,0.6 0 1,0 1.2,0 a 0.6,0.6 0 1,0 -1.2,0"/>
    <path android:fillColor="#80FFFFFF"
          android:pathData="M 12,94 m -0.5,0 a 0.5,0.5 0 1,0 1.0,0 a 0.5,0.5 0 1,0 -1.0,0"/>
    <path android:fillColor="#80FFFFFF"
          android:pathData="M 86,98 m -0.4,0 a 0.4,0.4 0 1,0 0.8,0 a 0.4,0.4 0 1,0 -0.8,0"/>
    <path android:fillColor="#80FFFFFF"
          android:pathData="M 22,96 m -0.4,0 a 0.4,0.4 0 1,0 0.8,0 a 0.4,0.4 0 1,0 -0.8,0"/>
</vector>
